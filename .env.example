# Default paths
DATA_DIR=./data/files
DATA_DOCS_PATHS_TEXT_FILE=./data/docs_paths.txt
DATA_WEBS_PATHS_TEXT_FILE=./data/webs_paths.txt
PERSIST_DIR=./index

# LLM
OLLAMA_MODEL=llama3.1:8b

# Embeddings: ollama (nomic-embed-text) or hf (sentence-transformers)

EMBEDDINGS_BACKEND=ollama
# EMBEDDINGS_BACKEND=hf
EMBEDDINGS_MODEL=bge-m3
# EMBEDDINGS_MODEL=nomic-embed-text
# EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

PROMPTS=default_es


# Retrieval / chunking
TOP_K=25
CHUNK_SIZE=800
CHUNK_OVERLAP=150
